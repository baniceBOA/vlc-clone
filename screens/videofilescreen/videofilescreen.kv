<VideoFileScreen>:
    BoxLayout:
        orientation: 'vertical'
        spacing: dp(8)
        padding: dp(8)
        MDTextField:
            id: search_field
            hint_text: 'Search videos'
            size_hint_x: 0.95
            pos_hint: {'center_x': 0.5}
            on_text: root.on_search(self.text)
        RecycleView:
            id:rv
            viewclass:'VideoCard'
            RecycleGridLayout:
                cols: 2
                default_size_hint:(1, None)
                default_size:(None, dp(250))
                size_hint_y:None
                height:self.minimum_height
                spacing:dp(25)
                padding:[dp(12), dp(8), dp(12), dp(8)]