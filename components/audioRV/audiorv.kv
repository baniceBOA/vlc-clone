<AudioRV>:
    orientation: 'vertical'
    RecyleView:
        id:audio_rv
        viewclass:'AudioFileView'
        RecycleGridLayout:
            cols: 1
            default_size_hint:(1, None)
            default_size:(None, dp(250))
            size_hint_y:None
            height:self.minimum_height
            spacing:dp(10)
            padding:[dp(12), dp(8), dp(12), dp(8)]

